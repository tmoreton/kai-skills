# Webhook Skill - Environment Variables
# Copy this file to .env and fill in your values

# Zapier Webhook URLs
# Get these from your Zapier webhook trigger setup
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/YOUR_ACCOUNT/YOUR_HOOK/

# Make (Integromat) Webhook URLs
# Get these from your Make webhook module
MAKE_WEBHOOK_URL=https://hook.make.com/YOUR_WEBHOOK_TOKEN

# Custom Endpoint Examples
CUSTOM_API_ENDPOINT=https://api.yourservice.com/webhook
INTERNAL_WEBHOOK_URL=http://localhost:3000/webhook

# Example API Keys (for use with send_with_auth action)
# Note: These are passed directly to the action, not read from env
EXAMPLE_BEARER_TOKEN=your_bearer_token_here
EXAMPLE_API_KEY=your_api_key_here
