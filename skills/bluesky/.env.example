# Bluesky AT Protocol API Credentials
# Get these from https://bsky.app/settings/app-passwords

# Your Bluesky handle (e.g., user.bsky.social) or DID
BLUESKY_IDENTIFIER=your-handle.bsky.social

# Your Bluesky app password (NOT your account password)
# Create one at: Settings > App Passwords
BLUESKY_PASSWORD=your-app-password-here

# Optional: Custom AT Protocol service URL
# Default is https://bsky.social (Bluesky's official server)
# BLUESKY_SERVICE=https://bsky.social
