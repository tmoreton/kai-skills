# Required for web search functionality
TAVILY_API_KEY=your_tavily_api_key_here

# Optional: TikTok Research API (for accurate stats and more data)
# Apply at: https://developers.tiktok.com/products/research-api
TIKTOK_RESEARCH_API_KEY=your_tiktok_research_api_key_here

# Optional: TikTok Display API (for user content)
# Apply at: https://developers.tiktok.com/apps
TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here
