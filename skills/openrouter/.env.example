# OpenRouter API Key
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Default model for chat completions (optional)
# See available models: https://openrouter.ai/docs#models
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Example usage for image generation:
# kai use openrouter generate_image prompt="A futuristic city at sunset with flying cars"
#
# Example usage for chat:
# kai use openrouter chat_completion prompt="Explain quantum computing in simple terms"
#
# List available image models:
# kai use openrouter list_models filter=image
