# LinkedIn API Skill Configuration
# Copy this file to .env and fill in your credentials

# =============================================================================
# REQUIRED: LinkedIn OAuth 2.0 Access Token
# =============================================================================
# Get your access token from LinkedIn Developer Portal:
# https://www.linkedin.com/developers/apps
#
# Required OAuth Scopes:
# - r_basicprofile: Read profile info (name, headline, photo)
# - w_member_social: Create posts as member
# - r_organization_social: Read organization posts (for analytics)
#
# Token expires in 60 days - refresh using refresh_token flow
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here

# =============================================================================
# OPTIONAL: OAuth 2.0 App Credentials (for token refresh)
# =============================================================================
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here

# =============================================================================
# OPTIONAL: Tavily API (for web search fallback)
# =============================================================================
# If LinkedIn API search is unavailable, Tavily provides web search fallback
# Get API key: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# =============================================================================
# Example Usage in config.yaml:
# =============================================================================
# skills:
#   linkedin:
#     access_token: ${LINKEDIN_ACCESS_TOKEN}
#     tavily_api_key: ${TAVILY_API_KEY}
