# Instagram API Skill Environment Variables
# Copy this file to .env and fill in your credentials

# ==========================================
# Instagram Basic Display API / Graph API
# ==========================================

# Primary access token for API requests
# Get this from: https://developers.facebook.com/tools/explorer/
# Or via OAuth flow for Basic Display API
INSTAGRAM_ACCESS_TOKEN=your_access_token_here

# Alternative token variable (alias)
INSTAGRAM_TOKEN=your_access_token_here

# ==========================================
# Instagram Graph API App Credentials
# ==========================================

# Required for hashtag search and some advanced features
# Get these from: https://developers.facebook.com/apps
INSTAGRAM_APP_ID=your_app_id_here
INSTAGRAM_APP_SECRET=your_app_secret_here

# ==========================================
# NOTES
# ==========================================

# Instagram Basic Display API:
# - Get user profile and media
# - Requires app review for production use
# - Docs: https://developers.facebook.com/docs/instagram-basic-display-api

# Instagram Graph API:
# - Requires Business or Creator Instagram account
# - Get insights, hashtag search, publish content
# - Docs: https://developers.facebook.com/docs/instagram-api

# Getting Access Tokens:
# 1. Create a Facebook app at https://developers.facebook.com/apps
# 2. Add Instagram Basic Display or Instagram API product
# 3. Configure settings and generate tokens
# 4. For production, implement proper OAuth flow

# Permissions Required:
# - instagram_graph_user_profile: Read user profile
# - instagram_graph_user_media: Read user media
# - instagram_graph_hashtag_search: Search hashtags (Business/Creator only)
# - instagram_graph_user_insights: Read insights (Business/Creator only)
