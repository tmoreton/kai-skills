# Google Sheets API Skill Configuration
# Copy this file to .env and fill in your credentials

# =============================================================================
# AUTHENTICATION: Choose ONE method (Service Account OR OAuth 2.0)
# =============================================================================

# -----------------------------------------------------------------------------
# OPTION 1: Service Account (Recommended for server-side automation)
# -----------------------------------------------------------------------------
# 1. Go to Google Cloud Console: https://console.cloud.google.com
# 2. Create a project or select existing one
# 3. Enable Google Sheets API and Google Drive API:
#    - APIs & Services > Library > Search "Google Sheets API" > Enable
#    - APIs & Services > Library > Search "Google Drive API" > Enable
# 4. Create Service Account:
#    - IAM & Admin > Service Accounts > Create
#    - Grant roles: "Editor" or "Viewer" as needed
# 5. Create JSON Key:
#    - Service Account > Keys > Add Key > Create New Key > JSON
# 6. Copy the entire JSON content (including newlines) and paste below
#    OR save to a file and use: GOOGLE_SERVICE_ACCOUNT_JSON=$(cat service-account.json)
#
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# -----------------------------------------------------------------------------
# OPTION 2: OAuth 2.0 (For user-level access to their own sheets)
# -----------------------------------------------------------------------------
# 1. Go to Google Cloud Console: https://console.cloud.google.com
# 2. Create OAuth 2.0 credentials:
#    - APIs & Services > Credentials > Create Credentials > OAuth client ID
#    - Application type: "Web application" or "Desktop app"
# 3. Set redirect URI (for web apps) or use http://localhost (for local)
# 4. Note the Client ID and Client Secret
# 5. Get refresh token via OAuth flow:
#    a) Visit: https://developers.google.com/oauthplayground
#    b) Select scopes: https://www.googleapis.com/auth/spreadsheets, https://www.googleapis.com/auth/drive
#    c) Exchange authorization code for refresh token
#
GOOGLE_CLIENT_ID=your_oauth_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_oauth_client_secret_here
GOOGLE_REFRESH_TOKEN=your_refresh_token_here

# Optional: Access token (short-lived, refresh_token is preferred)
GOOGLE_ACCESS_TOKEN=your_access_token_here

# Optional: Redirect URI for OAuth flow (default: http://localhost)
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# =============================================================================
# EXAMPLE USAGE IN config.yaml:
# =============================================================================
# skills:
#   google-sheets:
#     # Service Account method
#     service_account_json: ${GOOGLE_SERVICE_ACCOUNT_JSON}
#     # OR OAuth method
#     client_id: ${GOOGLE_CLIENT_ID}
#     client_secret: ${GOOGLE_CLIENT_SECRET}
#     refresh_token: ${GOOGLE_REFRESH_TOKEN}
