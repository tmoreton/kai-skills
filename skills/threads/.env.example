# Threads API Credentials
# Get these from Meta for Developers: https://developers.facebook.com/apps
# 
# Required Permissions:
# - threads_basic: Required for all API calls
# - threads_content_publish: Required for posting threads
# - threads_manage_replies: Required for managing replies
# - threads_read_replies: Required for reading replies

# Your Threads Access Token (obtained via OAuth flow)
THREADS_ACCESS_TOKEN=your_threads_access_token_here

# Your Threads User ID (from /me endpoint or app dashboard)
THREADS_USER_ID=your_threads_user_id_here

# Optional: App credentials (if using OAuth flow directly)
THREADS_APP_ID=your_app_id
THREADS_APP_SECRET=your_app_secret
