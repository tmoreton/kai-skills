# Facebook Pages API Credentials
# Get your access token from: https://developers.facebook.com/tools/explorer/
# For production, use a long-lived Page Access Token

# Required: Facebook Page Access Token
FACEBOOK_ACCESS_TOKEN=your_facebook_page_access_token_here

# Required: Facebook Page ID
# Find it at: https://www.facebook.com/me/pages -> Select your page -> Settings -> Page Info
FACEBOOK_PAGE_ID=your_page_id_here
