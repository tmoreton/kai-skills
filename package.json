{
  "name": "kai-skills",
  "version": "1.0.0",
  "description": "Portable skill library for Kai - works with Claude, ChatGPT, and other AI assistants",
  "private": true,
  "type": "module",
  "bin": {
    "kai-mcp": "./bin/kai-mcp.js"
  },
  "workspaces": [
    "packages/*",
    "skills/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint packages/*/src skills/*/handler.js",
    "format": "prettier --write packages/*/src skills/*/{handler.js,skill.yaml}"
  },
  "keywords": [
    "kai",
    "skills",
    "mcp",
    "ai-tools",
    "claude",
    "chatgpt"
  ],
  "author": "Kai",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0"
  }
}
